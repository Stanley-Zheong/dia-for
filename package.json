{
  "name": "dia-for",
  "version": "1.0.0",
  "description": "Public AI chat archive powered by Obsidian and Gemini.",
  "private": true,
  "scripts": {
    "content:manifest": "node scripts/generate-content-manifest.mjs",
    "content:sync": "bash scripts/sync-from-obsidian.sh",
    "build": "npm run content:manifest && next build --webpack",
    "build:cloudflare": "opennextjs-cloudflare build",
    "dev": "next dev",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "npm run content:manifest && vitest run",
    "verify:deploy": "sh -c 'echo \"== Deploy-relevant git status ==\"; status=\"$(git status --short -- src tests scripts content docs package.json package-lock.json next.config.ts tsconfig.json)\"; printf \"%s\\n\" \"$status\"; if [ -n \"$status\" ]; then echo \"Deploy verification failed: commit or remove the files listed above.\"; exit 1; fi; npm run lint && npm run typecheck && npm run test && npm run build'",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "dependencies": {
    "@google/genai": "^1.50.1",
    "@opennextjs/cloudflare": "^1.19.4",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "wrangler": "^4.85.0"
  }
}
